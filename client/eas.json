{
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_GRAPHQL_HTTP_URL": "http://192.168.1.57:4000/graphql"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_GRAPHQL_HTTP_URL": "$GRAPHQL_URL"
      }
    }
  }
}
