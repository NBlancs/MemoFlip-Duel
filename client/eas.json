{
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_GRAPHQL_HTTP_URL": "https://memoflip-production.up.railway.app/graphql"
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_GRAPHQL_HTTP_URL": "$GRAPHQL_URL"
      }
    }
  }
}
